# ── API Keys ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Paths ─────────────────────────────────────────────────────────────────────
# Absolute path to the assets directory (contains downloaded_pdfs/, pdf_images/, etc.)
DATA_DIR=/gdrive/MyDrive/VLM_Finetuning_OCR/assets

# ── Model IDs ─────────────────────────────────────────────────────────────────
CLOUD_MODEL_ID=openrouter/google/gemini-3-flash-preview
LOCAL_MODEL_ID=google/gemma-3-4b-it

# ── Token limits ──────────────────────────────────────────────────────────────
MAX_TOKENS_ANNOTATION=8000
MAX_TOKENS_EVAL=4096

# ── Pricing (USD per 1M tokens) ───────────────────────────────────────────────
PRICE_PER_1M_INPUT=0.5
PRICE_PER_1M_OUTPUT=3.0
